{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base",
        ":semanticCommits",
        ":semanticCommitTypeAll(chore)"
    ],
    "rangeStrategy": "bump",
    "labels": [
        "dependencies"
    ],
    "automerge": true,
    "automergeType": "squash",
    "commitMessageTopic": "{{{depName}}}",
    "commitMessageExtra": "updates: {{{updates}}}",
    "packageRules": [
        {
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": false,
            "labels": [
                "major-update"
            ]
        }
    ],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "dependencyDashboard": true
}
